{
  "project": "The Enrollment Squeeze",
  "package": "GitHub Pages static data story",
  "runtime": {
    "entrypoint": "index.html",
    "scripts": [
      "assets/plotly.min.js",
      "diagnostics-core.js",
      "filters-core.js",
      "app.js",
      "filters.js"
    ],
    "data": [
      "data/national.json",
      "data/national_enrollment.json",
      "data/states.json",
      "data/state_diagnostics.json",
      "data/counties.json",
      "data/institutions.json",
      "data/institution_diagnostics.json",
      "data/international.json",
      "data/context.json",
      "data/state_shapes.json",
      "data/map_meta.json"
